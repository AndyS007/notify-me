{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@api": ["./src/api"],
      "@api/*": ["./src/api/*"],
      "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      "@db": ["./src/db"],
      "@db/*": ["./src/db/*"],
      "@hooks": ["./src/hooks"],
      "@hooks/*": ["./src/hooks/*"],
      "@screens": ["./src/screens"],
      "@screens/*": ["./src/screens/*"],
      "@services": ["./src/services"],
      "@services/*": ["./src/services/*"],
      "@theme": ["./src/theme"],
      "@theme/*": ["./src/theme/*"],
      "@utils": ["./src/utils"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
